{
  "gateway": {
    "bind": "127.0.0.1",
    "port": 8000,
    "auth": {
      "enabled": true,
      "token_env": "OPENCLAW_AUTH_TOKEN"
    }
  },
  "agents": {
    "job_bot": {
      "name": "The Sniper",
      "workspace": "~/.openclaw/workspace-jobs",
      "routing": {
        "telegram_bot": "@OpenClawKevin"
      },
      "tools": {
        "exec": {
          "enabled": false
        },
        "write": {
          "enabled": false
        },
        "browser": {
          "enabled": true
        },
        "read": {
          "enabled": true,
          "allowed_paths": [
            "./knowledge_base/"
          ]
        },
        "nodes": {
          "enabled": false
        },
        "canvas": {
          "enabled": false
        },
        "llm_task": {
          "enabled": false
        },
        "computer": {
          "enabled": false
        }
      }
    },
    "developer": {
      "name": "The Researcher",
      "workspace": "~/.openclaw/workspace-dev",
      "routing": {
        "telegram_bot": "@OpenClawDev"
      },
      "sandbox": {
        "mode": "all",
        "workspaceAccess": "ro"
      },
      "scout_config": {
        "target_roles": [
          "Software Engineer Intern Summer 2026",
          "Data Science Intern Summer 2026",
          "Machine Learning Intern Summer 2026",
          "Product Management Intern Summer 2026"
        ],
        "locations": [
          "United States",
          "Remote",
          "New York, NY",
          "Chicago, IL",
          "San Francisco, CA"
        ],
        "keywords": [
          "Summer 2026",
          "internship",
          "sponsorship available",
          "OPT",
          "CPT",
          "visa sponsorship",
          "international students welcome"
        ],
        "exclude_keywords": [
          "US Citizen Only",
          "No Sponsorship",
          "Clearance Required"
        ]
      },
      "skills": [
        "market-research",
        "python-patterns",
        "continuous-learning",
        "byterover",
        "auto-updater"
      ],
      "tools": {
        "exec": {
          "enabled": true,
          "ask": "always"
        },
        "write": {
          "enabled": true,
          "ask": "always"
        },
        "browser": {
          "enabled": false
        },
        "read": {
          "enabled": true
        },
        "nodes": {
          "enabled": false
        },
        "canvas": {
          "enabled": false
        },
        "llm_task": {
          "enabled": false
        },
        "computer": {
          "enabled": false
        }
      }
    }
  }
}