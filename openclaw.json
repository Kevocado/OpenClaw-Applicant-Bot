{
  "$schema": "https://openctx.org/schema/openclaw.json",
  "_comment": "Hardened OpenClaw config — loopback only, token auth, exec approval required",
  "server": {
    "host": "127.0.0.1",
    "port": 3000
  },
  "auth": {
    "type": "token",
    "token": "${OPENCLAW_AUTH_TOKEN}"
  },
  "tools": {
    "exec": {
      "enabled": true,
      "ask": "always",
      "allowed_commands": [
        "python apply_agent.py*",
        "cat pending_approvals.json",
        "ls screenshots/"
      ]
    },
    "read_file": {
      "enabled": true,
      "allowed_paths": [
        "./knowledge_base/*",
        "./pending_approvals.json",
        "./screenshots/*"
      ]
    },
    "write_file": {
      "enabled": false
    },
    "nodes": {
      "enabled": false
    },
    "canvas": {
      "enabled": false
    },
    "llm_task": {
      "enabled": false
    },
    "browser": {
      "enabled": false
    },
    "computer": {
      "enabled": false
    }
  },
  "sandbox": false,
  "logging": {
    "level": "info",
    "file": "./logs/openclaw.log"
  }
}